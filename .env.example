# Copy to .env and set paths to your local data (see docs/data_layout.md).
# The data/ directory is gitignored and must never be committed.

FLORACCO_DB_PATH=data/sqlite/main.db
FLORACCO_DB_DUMP_PATH=data/sqlite/projects_at.sql
FLORACCO_DATA_ROOT=data/corpus
FLORACCO_IMAGES_ROOT=data/corpus/img

# Place pipeline (docs/reference/place_pipeline.md): the historic-name resolution
# batch (workflows/place_resolve.py) calls an LLM via OpenRouter. Get a key at
# https://openrouter.ai/keys (default model anthropic/claude-opus-4.8). Never commit it.
OPENROUTER_API_KEY=
