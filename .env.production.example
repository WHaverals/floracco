# Production / pilot environment. Set these as environment variables on the host
# (Render dashboard, or docker-compose). NEVER commit a real .env. The corpus
# data lives on the mounted disk, not in this file and not in git.

# Serve the built React app from FastAPI (single origin). Always 1 in deployment.
FLORACCO_SERVE_STATIC=1

# The one knob that matters: the working data root on the mounted disk.
# main.db, corrections.db, the derived pipeline outputs, and the search index
# all resolve under this automatically.
FLORACCO_DATA_DIR=/data/working

# Optional explicit overrides (defaults derive from FLORACCO_DATA_DIR):
#   FLORACCO_IMAGES_ROOT=/data/working/corpus/img
#   FLORACCO_DB_PATH=/data/working/sqlite/main.db
#   FLORACCO_CORRECTIONS_DB_PATH=/data/working/sqlite/corrections.db

# Used by the resettable-demo reset and the backup scripts (deploy/):
#   FLORACCO_PRISTINE_DIR=/data/pristine
#   FLORACCO_BACKUP_DIR=/data/backups
